# Database
DATABASE_URL=postgresql://oakville:oakville@localhost:5432/oakville_schools

# Redis
REDIS_URL=redis://localhost:6379

# Typesense
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=your-typesense-api-key

# API
API_PORT=3001

# Playwright
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_MAX_RETRIES=3

# Rate limits (milliseconds between requests)
RATE_LIMIT_HDSB=3000
RATE_LIMIT_HCDSB=3000
RATE_LIMIT_PRIVATE=5000
RATE_LIMIT_CHILDCARE=5000

# S3 storage (for raw HTML snapshots)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=oakville-schools-snapshots
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
